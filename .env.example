# ============================================
# Simple LMS - Environment Variables Example
# ============================================
# Salin file ini menjadi .env dan sesuaikan nilainya
# JANGAN commit file .env ke repository!

# Django Settings
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Settings (PostgreSQL)
DB_NAME=simple_lms_db
DB_USER=lms_user
DB_PASSWORD=lms_password123
DB_HOST=db
DB_PORT=5432
